<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_birthday_reminder" model="ir.cron">
        <field name="name">Birthday Reminder: Send Wishes</field>
        <field name="model_id" ref="model_birthday_reminder"/>
        <field name="state">code</field>
        <field name="code">model._cron_send_birthday_wishes()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
