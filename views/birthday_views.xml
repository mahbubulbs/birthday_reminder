<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_birthday" model="ir.actions.act_window">
        <field name="name">Birthdays</field>
        <field name="res_model">birthday.reminder</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_birthday_today': 1}</field>
    </record>

    <record id="view_birthday_list" model="ir.ui.view">
        <field name="name">birthday.reminder.list</field>
        <field name="model">birthday.reminder</field>
        <field name="arch" type="xml">
            <list string="Birthdays" decoration-success="is_birthday_today">
                <field name="name"/>
                <field name="email"/>
                <field name="birth_date"/>
                <field name="is_birthday_today" column_invisible="True"/>
                <field name="last_wish_year" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_birthday_form" model="ir.ui.view">
        <field name="name">birthday.reminder.form</field>
        <field name="model">birthday.reminder</field>
        <field name="arch" type="xml">
            <form string="Birthday">
                <header>
                    <button name="action_send_birthday_wish"
                            string="Send Wish Now"
                            type="object"
                            class="btn-primary"
                            invisible="not email"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="email" widget="email"/>
                        </group>
                        <group>
                            <field name="birth_date"/>
                            <field name="last_wish_year"/>
                            <field name="is_birthday_today"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_birthday_search" model="ir.ui.view">
        <field name="name">birthday.reminder.search</field>
        <field name="model">birthday.reminder</field>
        <field name="arch" type="xml">
            <search string="Birthdays">
                <field name="name"/>
                <field name="email"/>
                <filter name="birthday_today" string="Birthday Today"
                        domain="[('is_birthday_today', '=', True)]"/>
                <filter name="missing_email" string="Missing Email"
                        domain="[('email', '=', False)]"/>
            </search>
        </field>
    </record>
</odoo>
